# =============================================================================
# TurboVid — Aporia Bulk Video Tool
# Environment variable template. Copy to .env and fill in real values.
# NEVER commit the real .env file. See .gitignore.
# =============================================================================

# -----------------------------------------------------------------------------
# Service
# -----------------------------------------------------------------------------
BULKVID_ENV=local                       # local | staging | production
BULKVID_HOST=0.0.0.0
BULKVID_PORT=8788
BULKVID_LOG_LEVEL=INFO                  # DEBUG | INFO | WARN | ERROR
BULKVID_DATA_DIR=./data                 # production: /data/bulkvid

# -----------------------------------------------------------------------------
# Auth
# -----------------------------------------------------------------------------
# Comma-separated explicit emails (for individual exceptions).
BULK_TEAM_ALLOWLIST=

# Comma-separated whole-domain allowlist. ANY email in these domains is
# accepted. Most teams will only need this — leave BULK_TEAM_ALLOWLIST empty.
BULK_TEAM_DOMAINS=aporianetworks.com,teaminternet.com

# Comma-separated admin emails (have access to /admin API endpoints + can
# view/kill any job, not just their own).
ADMIN_ALLOWLIST=yoav@aporianetworks.com

# Google Workspace `hd` claim. Comma-separated list of allowed Workspaces.
# Empty disables the hd check entirely.
ALLOWED_HD=aporianetworks.com,teaminternet.com

# Admin panel HTTP Basic auth (separate from the API OAuth flow).
# Leave empty to disable the admin panel.
ADMIN_PANEL_USERNAME=yoav
ADMIN_PANEL_PASSWORD=tenta20

# LOCAL-DEV ONLY: when set, /jobs accepts ANY request without a bearer token
# and treats the caller as this email. Loud warning on every request.
# MUST be empty in production.
BULKVID_DEV_AUTH_BYPASS_EMAIL=

# -----------------------------------------------------------------------------
# OpenAI
# -----------------------------------------------------------------------------
# Used for: gpt-5.4-mini (script gen, prompt build, classifier), gpt-4o (vision).
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# kie.ai — image gen + upscale
# -----------------------------------------------------------------------------
# Comma-separated pool of kie.ai keys for round-robin with per-key cooldown.
# At least one key required.
KIE_AI_KEYS=
KIE_BASE_URL=https://api.kie.ai
KIE_CONNECT_TIMEOUT_SECONDS=10
KIE_TIMEOUT_SECONDS=120
KIE_RATE_LIMIT_COOLDOWN_SECONDS=60
KIE_MAX_IN_FLIGHT_IMAGE_TASKS=40

# -----------------------------------------------------------------------------
# Google Cloud — Vertex AI Gemini TTS + GCS
# -----------------------------------------------------------------------------
# Path to the Vertex AI service account JSON (project: amit-tts).
GOOGLE_APPLICATION_CREDENTIALS=
VERTEX_AI_PROJECT_ID=amit-tts
VERTEX_AI_LOCATION=us-central1

# GCS fallback storage.
GCS_BUCKET_NAME=aporia-unleash
GCS_CREDENTIALS_FILE=

# -----------------------------------------------------------------------------
# AWS S3 — primary storage (existing aporia-creative bucket)
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_BUCKET_NAME=aporia-creative

# -----------------------------------------------------------------------------
# Rendi.dev — ffmpeg-as-a-service
# -----------------------------------------------------------------------------
RENDI_API_KEY=
RENDI_BASE_URL=https://api.rendi.dev
RENDI_DEFAULT_VCPU=4
RENDI_MAX_COMMAND_RUN_SECONDS=300

# -----------------------------------------------------------------------------
# ZapCap — subtitle burn-in
# -----------------------------------------------------------------------------
ZAPCAP_API_KEY=
ZAPCAP_BASE_URL=https://api.zapcap.ai
ZAPCAP_TEMPLATE_ID=46d20d67-255c-4c6a-b971-31fddcfea7f0
ZAPCAP_SUBMIT_INTERVAL_SECONDS=1        # drop to 1s with BULKVID_FAST_ZAPCAP_SUBMIT
ZAPCAP_POLL_INTERVAL_SECONDS=10

# -----------------------------------------------------------------------------
# Article fetching
# -----------------------------------------------------------------------------
TAVILY_API_KEY=
TAVILY_TIMEOUT_SECONDS=15
SCRAPINGBEE_API_KEY=
SCRAPINGBEE_TIMEOUT_SECONDS=30
ARTICLE_MAX_CONTENT_CHARS=50000
ARTICLE_CACHE_TTL_SECONDS=3600

# -----------------------------------------------------------------------------
# Google Sheets
# -----------------------------------------------------------------------------
# Service account JSON used for sheet reads/writes.
SHEETS_SERVICE_ACCOUNT_FILE=
# Master DB sheet for metadata logging (matches existing Symphony pattern).
SYMPHONY_DB_SHEET_ID=10NgBy7DGUOkW15HHAQC4B-BP0dcCIX5yTnRCDowMkgc
SYMPHONY_DB_SHEET_TAB=SYMPHONY_DB
# Default spreadsheet for the local runner CLI (tools/run_local.py). When
# set, `python tools/run_local.py` (no --sheet-id flag) reads + writes this
# sheet. PA itself never uses this; Apps Script passes the sheet ID per
# request. Set this on machines that run the local CLI so the user doesn't
# retype the ID every invocation.
BULKVID_DEFAULT_SHEET_ID=

# -----------------------------------------------------------------------------
# Concurrency
# -----------------------------------------------------------------------------
# 10 = PythonAnywhere safe default (CPU-quota-aware).
# 40 = Hetzner setting (no quota; bumps batch throughput ~4x).
BULKVID_MAX_CONCURRENT_ROWS=10
BULKVID_SHEET_WRITE_INTERVAL_SECONDS=5
BULKVID_MAX_ROWS_PER_BATCH=5000

# Per-provider concurrency caps. Independent of MAX_CONCURRENT_ROWS — cap
# in-flight requests against ONE external provider across the whole worker.
# Added 2026-06-08 after a 277-row simple-tab batch hit 46% failures from
# Rendi platform overload + Gemini TTS per-minute quota bursts. v1 guesses;
# retune from production [rendi/gemini_tts]_semaphore_wait log lines.
BULKVID_RENDI_MAX_CONCURRENT=6
BULKVID_GEMINI_TTS_MAX_CONCURRENT=4
# Hard per-minute cap on Gemini TTS generate_content calls. The Vertex quota
# ``generate_content_requests_per_minute`` on amit-tts is 15 RPM — anything
# above this returns 429 RESOURCE_EXHAUSTED. Counted at the call boundary so
# each retry burns a slot. Bump only after the project quota is raised.
BULKVID_GEMINI_TTS_MAX_PER_MINUTE=15

# -----------------------------------------------------------------------------
# Feature flags
# -----------------------------------------------------------------------------
BULKVID_INTERNAL_PARALLEL=1
BULKVID_ARTICLE_CACHE=1
BULKVID_LANGUAGE_CACHE=1
BULKVID_SHEET_BATCH_WRITES=1
BULKVID_KIE_KEY_POOL=1
BULKVID_FAST_ZAPCAP_SUBMIT=0

# -----------------------------------------------------------------------------
# Cost guards
# -----------------------------------------------------------------------------
BULKVID_COST_PER_BATCH_USD_CAP=200
BULKVID_COST_PER_DAY_USD_CAP=500
BULKVID_COST_PER_MONTH_USD_CAP=5000
BULKVID_KILL_SWITCH=0

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
SENTRY_DSN=
SLACK_ALERT_WEBHOOK=
